<%- include("partials/header.ejs") %>
<body>
    <h1>Quote Finder</h1>
    <form action="/searchByKeyword">
        Keyword:
        <input type="text" name="keyword">
        <button>Search by Keyword</button>
    </form>
    <br>
    <form action="/searchByAuthor">
        <select name="authorId">
            <% for (author of authors) { %>
            <option value="<%=author.authorId%>">
                <%=author.firstName%> <%=author.lastName%>
            </option>
            <% } %>
        </select>
        <button>Search by Author</button>
    </form>

    <form action="/searchByCategory">
        <select name="categories">
            <% for (quote of quotes) { %>
            <option value="<%=quote.category%>">
                <%=quote.category%>
            </option>
            <% } %>
        </select>
        <button>Search by Category</button>
    </form>

    <form action="/searchByLikes">
        <label for="minLikes">Min Likes:</label>
        <input type="number" name="minLikes">
        <label for="maxLikes">Max Likes:</label>
        <input type="number" name="maxLikes">
        <button>Search by Likes</button>
    </form>
    
    <%- include("partials/footer.ejs") %>
</body>
</html>